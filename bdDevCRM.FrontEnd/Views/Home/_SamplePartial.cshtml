@* Views/CRM/Contacts/_SamplePartial.cshtml
   This is loaded dynamically into #contentArea via JavaScript fetch().
   No <html>, <head>, <body> tags — just the inner content.
*@

@model IEnumerable<dynamic>

<div class="page-container">

    <!-- Page Header Row -->
    <div class="page-header-row">
        <div class="page-title-area">
            <h1 class="page-title">Contacts</h1>
            <p class="page-subtitle">Manage all CRM contacts</p>
        </div>
        <div class="page-actions">
            <button class="btn btn-primary" id="btnAddContact">
                <i class="fa-solid fa-plus"></i>
                Add Contact
            </button>
            <button class="btn btn-outline" id="btnExport">
                <i class="fa-solid fa-file-export"></i>
                Export
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon bg-blue"><i class="fa-solid fa-address-book"></i></div>
            <div class="stat-info">
                <span class="stat-value">1,284</span>
                <span class="stat-label">Total Contacts</span>
            </div>
            <span class="stat-trend positive">↑ 12%</span>
        </div>
        <div class="stat-card">
            <div class="stat-icon bg-green"><i class="fa-solid fa-user-check"></i></div>
            <div class="stat-info">
                <span class="stat-value">948</span>
                <span class="stat-label">Active</span>
            </div>
            <span class="stat-trend positive">↑ 8%</span>
        </div>
        <div class="stat-card">
            <div class="stat-icon bg-orange"><i class="fa-solid fa-clock"></i></div>
            <div class="stat-info">
                <span class="stat-value">56</span>
                <span class="stat-label">Pending Follow-up</span>
            </div>
            <span class="stat-trend negative">↑ 3%</span>
        </div>
        <div class="stat-card">
            <div class="stat-icon bg-purple"><i class="fa-solid fa-star"></i></div>
            <div class="stat-info">
                <span class="stat-value">280</span>
                <span class="stat-label">VIP Contacts</span>
            </div>
            <span class="stat-trend positive">↑ 5%</span>
        </div>
    </div>

    <!-- Kendo Grid Container -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Contact List</h3>
            <div class="card-tools">
                <input type="text" class="search-input-inline" placeholder="Quick search..." id="quickSearch" />
            </div>
        </div>
        <div class="card-body p-0">
            <!-- Kendo Grid renders here -->
            <div id="contactsGrid"></div>
        </div>
    </div>

</div>

<!-- ── Scoped Styles for this partial ── -->
<style>
.page-container { padding: 0; }

.page-header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
}

.page-title {
    font-family: var(--font-brand);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
}

.page-subtitle {
    font-size: var(--font-size-sm);
    color: var(--text-muted);
}

.page-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 18px;
    border-radius: var(--border-radius-sm);
    font-size: var(--font-size-base);
    font-weight: 500;
    cursor: pointer;
    border: 1px solid transparent;
    transition: all var(--transition-fast);
}

.btn-primary {
    background: var(--brand-primary);
    color: white;
    border-color: var(--brand-primary);
}

.btn-primary:hover {
    background: var(--brand-primary-hover);
}

.btn-outline {
    background: transparent;
    color: var(--text-secondary);
    border-color: var(--border-color);
}

.btn-outline:hover {
    background: var(--bg-page);
    color: var(--text-primary);
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 24px;
}

.stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    padding: 16px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: var(--shadow-sm);
}

.stat-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 16px;
    flex-shrink: 0;
}

.stat-info {
    display: flex;
    flex-direction: column;
    flex: 1;
}

.stat-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
}

.stat-label {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
}

.stat-trend {
    font-size: var(--font-size-xs);
    font-weight: 600;
    margin-left: auto;
    padding: 3px 6px;
    border-radius: 4px;
}

.stat-trend.positive { background: #dcfce7; color: #16a34a; }
.stat-trend.negative { background: #fef9c3; color: #ca8a04; }

[data-theme="dark"] .stat-trend.positive { background: rgba(22,163,74,0.15); }
[data-theme="dark"] .stat-trend.negative { background: rgba(202,138,4,0.15); }

/* Card */
.card {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
}

.card-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
}

.card-title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
}

.card-body { padding: 20px; }
.card-body.p-0 { padding: 0; }

.search-input-inline {
    height: 34px;
    padding: 0 12px;
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-sm);
    background: var(--bg-input);
    color: var(--text-primary);
    font-size: var(--font-size-sm);
    font-family: var(--font-ui);
    width: 220px;
}

.search-input-inline:focus {
    border-color: var(--brand-primary);
    outline: none;
    box-shadow: 0 0 0 3px rgba(26,86,219,0.1);
}

/* Kendo Grid wrapper */
#contactsGrid {
    min-height: 300px;
}
</style>

<!-- ── Partial-specific Script ── -->
<script>
(function() {
    // This runs after fetch() injects the HTML into #contentArea
    // Kendo Grid initialization example
    if (typeof kendo !== 'undefined' && $('#contactsGrid').length) {
        $('#contactsGrid').kendoGrid({
            dataSource: {
                data: [
                    { id:1, name:'Alice Johnson',    email:'alice@company.com',   phone:'+1-555-0101', company:'TechCorp',   status:'Active' },
                    { id:2, name:'Bob Smith',        email:'bob@enterprise.com',  phone:'+1-555-0102', company:'EnterpriseCo', status:'Active' },
                    { id:3, name:'Carol White',      email:'carol@startup.io',    phone:'+1-555-0103', company:'StartupIO',  status:'Pending' },
                    { id:4, name:'David Lee',        email:'david@globalfirm.com',phone:'+1-555-0104', company:'GlobalFirm', status:'Active' },
                    { id:5, name:'Emma Davis',       email:'emma@consulting.net', phone:'+1-555-0105', company:'Consulting+',status:'VIP' }
                ],
                pageSize: 10
            },
            pageable: { refresh: true, pageSizes: [10, 25, 50] },
            sortable: true,
            filterable: true,
            resizable: true,
            columns: [
                { field:'name',    title:'Name',    width:200 },
                { field:'email',   title:'Email',   width:220 },
                { field:'phone',   title:'Phone',   width:150 },
                { field:'company', title:'Company', width:160 },
                {
                    field:'status', title:'Status', width:100,
                    template: function(d) {
                        const colors = { Active:'green', Pending:'orange', VIP:'purple' };
                        const c = colors[d.status] || 'blue';
                        return `<span style="
                            background:var(--brand-${c === 'green' ? 'success' : c === 'orange' ? 'warning' : 'purple'});
                            color:white;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600;">
                            ${d.status}</span>`;
                    }
                },
                {
                    title:'Actions', width:120, filterable:false, sortable:false,
                    template: '<button class="btn btn-outline" style="padding:4px 10px;font-size:11px;">Edit</button>'
                }
            ]
        });
    }
})();
</script>
